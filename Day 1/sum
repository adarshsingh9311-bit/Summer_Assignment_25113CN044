import java.util.*;

public class Sum {
    public static void main(String[] args) {

        int sum = 0;

        // input
        try ( Scanner scanner = new Scanner(System.in)) {
            int n = scanner.nextInt();

             for(int i=0;i<=n;i++){

                sum = sum + i;
             }
         }

        System.out.println("The sum is: " +sum);
    }
}


  
